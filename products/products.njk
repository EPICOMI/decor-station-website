---
pagination:
  data: products
  size: 1
  alias: item
  addAllPagesToCollections: true
permalink: "products/{{ item.id }}/"
layout: base.njk
---

{% if item.id and item.name %}
<a href="{{ '/catalog/' | relativeUrl(page.url) }}" class="pd-back-link" aria-label="Back to catalog">
  <svg class="pd-back-arrow" width="24" height="16" viewBox="0 0 24 16" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 8H3M10 1.5L3 8l7 6.5" />
  </svg>
  <span>Back</span>
</a>

<div class="product-detail">

  <div class="pd-gallery">
    {% set allImgs = item.images if item.images else ([item.image] if item.image else []) %}

    {% if allImgs | length > 1 %}
    <button class="pd-arrow pd-prev" aria-label="Previous image">&#8249;</button>
    {% endif %}

    <div class="pd-image-stage">
      {% for img in allImgs %}
        <img
          src="{{ img | relativeUrl(page.url) }}"
          alt="{{ item.name }} – image {{ loop.index }}"
          class="pd-img{{ ' active' if loop.first }}"
          draggable="false"
        >
      {% endfor %}
    </div>

    {% if allImgs | length > 1 %}
    <button class="pd-arrow pd-next" aria-label="Next image">&#8250;</button>
    {% endif %}

    {% if allImgs | length > 1 %}
    <div class="pd-dots">
      {% for img in allImgs %}
        <span class="pd-dot{{ ' active' if loop.first }}" data-index="{{ loop.index0 }}"></span>
      {% endfor %}
    </div>
    {% endif %}
  </div>

  <div class="pd-info">
    <p class="category">{{ item.category }}</p>
    <h2>{{ item.name }}</h2>
    <p class="pd-desc">{{ item.description }}</p>

    {% if item.price %}
      <p class="price pd-price">{{ item.price }}</p>
    {% endif %}

    <div class="pd-specs">
      {% if item.unitsAvailable %}
        <div class="pd-spec-item">
          <span class="pd-spec-label">Units Available:</span>
          <span class="pd-spec-value">{{ item.unitsAvailable }}</span>
        </div>
      {% endif %}
      {% if item.estimatedShippingTime %}
        <div class="pd-spec-item">
          <span class="pd-spec-label">Estimated Shipping:</span>
          <span class="pd-spec-value">{{ item.estimatedShippingTime }}</span>
        </div>
      {% endif %}
    </div>

    <div class="pd-actions">
      <a href="https://wa.me/65XXXXXXXX?text=Hi!%20I'm%20interested%20in%20the%20{{ item.name | urlencode }}"
         class="btn-buy">
        Buy
      </a>
      <a href="https://wa.me/65XXXXXXXX?text=Hi!%20Can%20you%20tell%20me%20more%20about%20the%20{{ item.name | urlencode }}"
         class="btn-info">
        Find out more
      </a>
    </div>
  </div>

</div>

<script src="{{ '/js/product-gallery.js' | relativeUrl(page.url) }}"></script>
{% endif %}