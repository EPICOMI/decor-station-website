<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }} | Decor Station</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ '/css/style.css' | relativeUrl(page.url) }}">
  <link rel="preload" as="image" href="{{ '/images/logo.png' | relativeUrl(page.url) }}">
</head>
<body class="page-{{ title | lower | replace(' ', '-') }}">
  <header class="site-header">
    <a href="{{ '/' | relativeUrl(page.url) }}">
      <img src="{{ '/images/logo.png' | relativeUrl(page.url) }}" alt="Decor Station" class="logo" width="2048" height="2048" fetchpriority="high">
    </a>
    <h1>DECOR STATION <span class="tagline">by Sonia</span></h1>

    <button
      class="hamburger-btn"
      id="menuToggleBtn"
      aria-expanded="false"
      aria-label="Open menu"
      aria-controls="siteNav">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </header>

  <div class="overlay" id="menuOverlay"></div>

  <nav class="site-nav" id="siteNav">
    <a href="{{ '/' | relativeUrl(page.url) }}">Home</a>
    <a href="{{ '/catalog/' | relativeUrl(page.url) }}">Catalog</a>
    <a href="{{ '/about/' | relativeUrl(page.url) }}">About</a>
    <a href="{{ '/contact/' | relativeUrl(page.url) }}">Contact</a>
    <hr>
    <a href="{{ '/catalog/?cat=Vases' | relativeUrl(page.url) }}">Vases</a>
    <a href="{{ '/catalog/?cat=Mirrors' | relativeUrl(page.url) }}">Mirrors</a>
    <a href="{{ '/catalog/?cat=Lighting' | relativeUrl(page.url) }}">Lighting</a>
  </nav>

  <main>
    {{ content | safe }}
  </main>

  <footer>
    <nav class="footer-links">
      <a href="{{ '/about/' | relativeUrl(page.url) }}">About</a>
      <a href="{{ '/contact/' | relativeUrl(page.url) }}">Contact</a>
    </nav>
    <p>&copy; 2026 Decor Station</p>
  </footer>

  <script src="{{ '/js/cycle.js' | relativeUrl(page.url) }}"></script>
  <script src="{{ '/js/menu.js' | relativeUrl(page.url) }}"></script>
</body>
</html>